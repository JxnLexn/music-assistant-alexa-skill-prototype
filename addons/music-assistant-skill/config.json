{
  "name": "Music Assistant Alexa Skill",
  "version": "0.0.53-beta",
  "slug": "music_assistant_skill",
  "image": "ghcr.io/jxnlexn/music-assistant-skill",
  "description": "Home Assistant add-on for provisioning and hosting the Music Assistant Alexa skill.",
  "url": "https://github.com/jxnlexn/music-assistant-alexa-skill-prototype",
  "arch": [
    "aarch64",
    "amd64"
  ],
  "startup": "services",
  "boot": "auto",
  "ports": {
    "5000/tcp": 5000
  },
  "ports_description": {
    "5000/tcp": "Skill API / setup UI port"
  },
  "options": {
    "SKILL_HOSTNAME": "",
    "MA_HOSTNAME": "",
    "APP_USERNAME": "",
    "APP_PASSWORD": "",
    "LOCALE": "de-DE",
    "AWS_DEFAULT_REGION": "us-east-1",
    "TZ": "America/Chicago",
    "SKIP_URL_VALIDATION": false
  },
  "schema": {
    "SKILL_HOSTNAME": "str",
    "MA_HOSTNAME": "str",
    "APP_USERNAME": "str",
    "APP_PASSWORD": "str",
    "LOCALE": "str",
    "AWS_DEFAULT_REGION": "str",
    "TZ": "str",
    "SKIP_URL_VALIDATION": "bool"
  },
  "webui": "http://[HOST]:[PORT:5000]/setup",
  "map": [],
  "ingress": false,
  "host_network": false
}
